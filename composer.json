{
  "name": "php-opcua/opcua-client-ext-transport-pubsub",
  "description": "OPC UA PubSub Subscriber for PHP — UDP + UADP + JSON, extends opcua-client",
  "homepage": "https://github.com/php-opcua/opcua-client-ext-transport-pubsub",
  "support": {
    "issues": "https://github.com/php-opcua/opcua-client-ext-transport-pubsub/issues",
    "source": "https://github.com/php-opcua/opcua-client-ext-transport-pubsub",
    "docs": "https://www.php-opcua.com/documentation/opcua-client-ext-transport-pubsub"
  },
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Gianfrancesco Aurecchia",
      "email": "gianfri@php-opcua.com"
    }
  ],
  "keywords": [
    "opcua",
    "opc-ua",
    "opc ua",
    "pubsub",
    "publish-subscribe",
    "uadp",
    "udp",
    "multicast",
    "industrial",
    "iiot",
    "industry-4.0",
    "subscriber"
  ],
  "autoload": {
    "psr-4": {
      "PhpOpcua\\Client\\ExtTransportPubSub\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhpOpcua\\Client\\ExtTransportPubSub\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../opcua-client",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-sockets": "*",
    "php-opcua/opcua-client": "^4.4@dev|dev-master",
    "psr/log": "^3.0",
    "psr/event-dispatcher": "^1.0"
  },
  "require-dev": {
    "pestphp/pest": "^3.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "scripts": {
    "format": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes",
    "format:check": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --dry-run --diff"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
